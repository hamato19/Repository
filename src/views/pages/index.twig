{% extends "layouts.master" %}

{% block content %}
<section class="landing-hero bg-primary text-white py-20 text-center">
    <h1 class="text-5xl font-bold">عالم الاشتراكات الرقمية بين يديك</h1>
    <p class="mt-4 text-xl">خدمات مضمونة، تسليم فوري، وأسعار لا تقبل المنافسة</p>
    <a href="#plans" class="mt-8 inline-block bg-accent text-white px-10 py-3 rounded-full font-bold">تصفح الباقات</a>
</section>

<section id="plans" class="py-20 container">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="border rounded-xl p-6 text-center shadow-md">
            <h3 class="text-2xl font-bold">يوتيوب بريميوم</h3>
            <p class="text-gray-500 mt-2">سنة كاملة - حساب خاص</p>
            <div class="text-3xl font-bold my-4">49 ر.س</div>
            <a href="/products/youtube" class="btn btn-primary w-full">شراء الآن</a>
        </div>
        
        <div class="border rounded-xl p-6 text-center shadow-lg border-primary scale-105 bg-blue-50">
            <h3 class="text-2xl font-bold text-primary">شاهد VIP</h3>
            <p class="text-gray-500 mt-2">باقة الرياضة والمسلسلات</p>
            <div class="text-3xl font-bold my-4">120 ر.س</div>
            <a href="/products/shahid" class="btn btn-primary w-full">شراء الآن</a>
        </div>
    </div>
</section>
{% endblock %}
